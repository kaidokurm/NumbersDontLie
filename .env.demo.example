# Numbers Don't Lie - Demo Environment Example
# Usage:
#   cp .env.demo.example .env
#   docker compose up -d --build

# Postgres
POSTGRES_DB=ndl
POSTGRES_USER=ndl
POSTGRES_PASSWORD=ndl_password
POSTGRES_PORT=5432

# Backend
SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8080
DATABASE_URL=jdbc:postgresql://localhost:5432/ndl
DATABASE_USER=ndl
DATABASE_PASSWORD=ndl_password
APP_TOKEN_PEPPER=replace-with-openssl-rand-base64-48
APP_DATA_ENCRYPTION_KEY=replace-with-openssl-rand-base64-48

# Frontend/Auth
VITE_AUTH0_AUDIENCE=https://numbers-dont-lie-api

# AI (optional, but recommended for demoing AI insights)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Demo flags
DEMO_MODE=true
VITE_DEMO_MODE=true

# Email via MailHog (for verification/reset demo)
APP_EMAIL_ENABLED=true
APP_EMAIL_FROM_ADDRESS=noreply@numbersdontlie.app
APP_EMAIL_FROM_NAME=Numbers Don't Lie
APP_EMAIL_FRONTEND_URL=http://localhost:5173
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS=false
MAILHOG_UI_PORT=8025

# Optional HTTPS (local)
SERVER_SSL_ENABLED=false
SERVER_SSL_KEY_STORE=
SERVER_SSL_KEY_STORE_PASSWORD=
SERVER_SSL_KEY_STORE_TYPE=PKCS12
SERVER_SSL_KEY_ALIAS=tomcat
