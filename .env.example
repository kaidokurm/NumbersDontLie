# Postgres (local)
POSTGRES_DB=ndl
POSTGRES_USER=ndl
POSTGRES_PASSWORD=ndl_password
POSTGRES_PORT=5432

# Backend
SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8080
DATABASE_URL=jdbc:postgresql://localhost:5432/ndl
DATABASE_USER=ndl
DATABASE_PASSWORD=ndl_password
APP_TOKEN_PEPPER=change-me-pepper
APP_DATA_ENCRYPTION_KEY=change-me-strong-key

# Frontend
VITE_AUTH0_AUDIENCE=https://numbers-dont-lie-api

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Demo flags (optional)
DEMO_MODE=false
VITE_DEMO_MODE=false

# Email / SMTP (optional)
# For reviewer demo with MailHog, set APP_EMAIL_ENABLED=true and keep MAIL_HOST=mailhog, MAIL_PORT=1025.
# MailHog inbox UI will be at http://localhost:8025 when using docker-compose.
APP_EMAIL_ENABLED=false
APP_EMAIL_FROM_ADDRESS=noreply@numbersdontlie.app
APP_EMAIL_FROM_NAME=Numbers Don't Lie
APP_EMAIL_FRONTEND_URL=http://localhost:5173
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS=false
MAILHOG_UI_PORT=8025

# Optional HTTPS (encryption in transit) for backend
# Generate a local PKCS12 keystore and set these when enabling HTTPS locally.
SERVER_SSL_ENABLED=false
SERVER_SSL_KEY_STORE=
SERVER_SSL_KEY_STORE_PASSWORD=
SERVER_SSL_KEY_STORE_TYPE=PKCS12
SERVER_SSL_KEY_ALIAS=tomcat
